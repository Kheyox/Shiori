{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Shiori",
  "version": "1.1.0",
  "identifier": "app.shiori.desktop",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Shiori — convertisseur Kobo",
        "width": 1280,
        "height": 860,
        "minWidth": 900,
        "minHeight": 640,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU0ODhCNDM0NUY2QkE2ODIKUldTQ3BtdGZOTFNJNUNjc2ttOWdaU3hEREFrNGFVdUVpK0F2dEt4ZGh5clU4VjhzZ3VJeklYd3kK",
      "endpoints": [
        "https://github.com/Kheyox/Shiori/releases/download/latest/update.json"
      ]
    }
  }
}